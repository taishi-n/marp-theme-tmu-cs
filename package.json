{
  "name": "marp-theme-tmu-cs",
  "version": "0.2.0",
  "description": "TMU-CS Marp theme with JS citation processing, step-based code highlighting, math annotations, and external code inclusion.",
  "license": "MIT",
  "type": "module",
  "files": [
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "engine.mjs",
    "index.mjs",
    "scripts/",
    "src/",
    "theme/",
    "vendor/csl/ieee.csl"
  ],
  "bin": {
    "marp-tmu-cs": "scripts/marp-tmu-cs.mjs"
  },
  "exports": {
    ".": "./index.mjs",
    "./engine": "./engine.mjs",
    "./engine.mjs": "./engine.mjs",
    "./theme": "./theme/tmu-cs.css",
    "./theme.css": "./theme/tmu-cs.css",
    "./theme/tmu-cs.css": "./theme/tmu-cs.css",
    "./csl/ieee.csl": "./vendor/csl/ieee.csl"
  },
  "keywords": [
    "marp",
    "marpit",
    "theme",
    "slides",
    "shiki",
    "citation-js",
    "citeproc"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:html": "cd examples && marp --engine ../engine.mjs slides.md -o dist/slides.html",
    "build:html:standalone": "cd examples && node ../scripts/marp-tmu-cs.mjs --standalone --engine ../engine.mjs slides.md -o dist/slides.standalone.html",
    "build:pdf": "cd examples && marp --engine ../engine.mjs slides.md -o dist/slides.pdf",
    "build:pptx": "cd examples && marp --engine ../engine.mjs --pptx --pptx-editable slides.md -o dist/slides.pptx",
    "test": "node --test",
    "watch": "cd examples && marp --engine ../engine.mjs --watch slides.md -o dist/slides.html"
  },
  "dependencies": {
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-bibtex": "^0.7.21",
    "@citation-js/plugin-csl": "^0.7.22",
    "@marp-team/marp-cli": "4.4.0",
    "@shikijs/transformers": "4.0.2",
    "@xmldom/xmldom": "^0.9.10",
    "citeproc": "^2.4.63",
    "js-yaml": "4.1.1",
    "shiki": "4.0.2",
    "wavegram": "^0.1.0"
  }
}
